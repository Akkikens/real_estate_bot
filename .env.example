# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./real_estate.db

# ─── Buyer profile ───────────────────────────────────────────────────────────
BUYER_MAX_PRICE=750000
BUYER_DOWN_PAYMENT=55000
BUYER_TARGET_CITIES=Richmond,Oakland,Berkeley,Albany,El Cerrito,Emeryville,Fremont

# ─── Scoring ─────────────────────────────────────────────────────────────────
ALERT_SCORE_THRESHOLD=65

# ─── Email alerts ────────────────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_TO_EMAIL=akshaykalapgar23@gmail.com

# ─── SMS (Twilio) — optional ─────────────────────────────────────────────────
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_TO_PHONE=

# ─── Telegram — optional ─────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Mortgage assumptions ─────────────────────────────────────────────────────
MORTGAGE_RATE=0.0725
MORTGAGE_TERM_YEARS=30
PROPERTY_TAX_RATE=0.0125
INSURANCE_RATE=0.005
PMI_RATE=0.005
MAINTENANCE_RATE=0.01
VACANCY_RATE=0.05

# ─── Bay Area room-rental estimate ($/mo per room) ────────────────────────────
ROOM_RENTAL_LOW=1000
ROOM_RENTAL_MID=1400
ROOM_RENTAL_HIGH=1800

# ─── Zillow (RapidAPI) — free tier: 500 req/mo, paid: $10/mo ─────────────────
# Get key at: https://rapidapi.com/apimaker/api/zillow-com1
ZILLOW_RAPIDAPI_KEY=

# ─── Realtor.com (RapidAPI) — optional for more reliable access ──────────────
# Get key at: https://rapidapi.com/apidojo/api/realtor-com4
REALTOR_RAPIDAPI_KEY=

# ─── Rate limiting ────────────────────────────────────────────────────────────
REDFIN_DELAY_SECONDS=3
ZILLOW_DELAY_SECONDS=5
REALTOR_DELAY_SECONDS=4
CRAIGSLIST_DELAY_SECONDS=5
REQUEST_TIMEOUT_SECONDS=20

# ─── Outreach mode: draft | approve | auto ───────────────────────────────────
OUTREACH_MODE=draft
